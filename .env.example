# Database
DATABASE_URL=postgresql://tprm:tprm_password@localhost:5432/tprm?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# S3-compatible storage (MinIO dev / Wasabi prod)
# For Wasabi: S3_ENDPOINT=https://s3.us-east-1.wasabisys.com
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET_ARTIFACTS=tprm-artifacts
S3_BUCKET_REPORTS=tprm-reports

# Microsoft Entra ID
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-api-client-id
ENTRA_SPA_CLIENT_ID=your-spa-client-id

# Claude API (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=TPRM Platform

# Application
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
JWT_AUDIENCE=api://your-api-client-id
